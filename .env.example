NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# GitHub — reportar issues/mejoras desde la app (solo servidor)
# Token con permiso de Issues (read/write) sobre el repo.
GITHUB_TOKEN=your-github-token
GITHUB_OWNER=jlsaco
GITHUB_REPO=financial-kj

# MCP server (solo servidor) — permite que Claude lea/escriba la app vía /api/mcp
# Secreto compartido del MCP. El mismo valor va en Amplify y en la config del
# cliente (header "Authorization: Bearer <MCP_AUTH_TOKEN>").
MCP_AUTH_TOKEN=genera-un-secreto-largo-aqui
